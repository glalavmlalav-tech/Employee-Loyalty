rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default catch-all allows read/write for seamless username/password access
    match /{document=**} {
      allow read, write: if true;
    }

    // Employees rules
    match /employees/{employeeId} {
      allow read, write: if true;
    }

    // Activities rules
    match /activities/{activityId} {
      allow read, write: if true;
    }

    // Gift logs rules
    match /gifts/{giftId} {
      allow read, write: if true;
    }

    // App Users rules
    match /app_users/{username} {
      allow read, write: if true;
    }
  }
}
